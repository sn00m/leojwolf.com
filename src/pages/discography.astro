---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReleaseCard from '../components/ReleaseCard.astro';
import { getCollection } from 'astro:content';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf()
);
---

<BaseLayout title="Leo Wolf - Discography">
<section class="content-container">
    <div id="discography-page">
        <h2>Discography</h2>
        <div class="releases-container">
            <ul class="releases-list">
                {releases.map((release) => (
                    <ReleaseCard
                        slug={release.id}
                        artist={release.data.artist}
                        albumTitle={release.data.albumTitle}
                        coverImage={release.data.coverImage}
                        releaseDate={release.data.releaseDate}
                        format={release.data.format}
                        label={release.data.label}
                    />
                ))}
            </ul>
        </div>
    </div>
</section>
</BaseLayout>
